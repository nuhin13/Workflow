#!/usr/bin/env bash
# harness pre-push hook: protect main/development locally (PRs only).
# Escape hatch for CI/admin: HARNESS_ALLOW_PUSH=1 git push ...
[ "$HARNESS_ALLOW_PUSH" = "1" ] && exit 0
while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/main|refs/heads/dev|refs/heads/development)
      echo "harness: ✋ direct push to ${remote_ref#refs/heads/} blocked — open a PR." >&2
      exit 1 ;;
  esac
done
exit 0
